{
  "name": "value-investment-tools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "preview:local": "vite preview --host 127.0.0.1 --port 4173",
    "dev:cf": "npm run build && wrangler dev",
    "dev:cf:test": "npm run build && wrangler dev --ip 127.0.0.1 --port 4173",
    "docs:screenshots": "node scripts/capture-readme-screenshots.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report .artifacts/playwright-report",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "lucide-react": "0.453.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.28.0",
    "recharts": "2.13.0",
    "yaml": "^2.8.1",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "wrangler": "^4.90.0"
  }
}
